# git
alias gc-b='git checkout -b'
alias gc-m='git commit -m'
alias gac-m='git add -A && git commit -m'
alias gp='git push'
alias gs='git status'

# global
alias -g @g='| grep'
alias -g @l='| less'

# safety
alias cp='cp -i'

# ls
alias l='ls -CF'
alias la='ls -A'
alias ll='ls -laF'

# navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# ClaudeCode
alias cl='claude'
alias ccusage='npx ccusage'
